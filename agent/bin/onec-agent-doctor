#!/usr/bin/env bash
set -euo pipefail

project_root="${ONEC_PROJECT_ROOT:-/workspace/project}"
registry_path="${ONEC_AGENT_REGISTRY:-/opt/onec-agent/registry.json}"

status=0

check_path() {
  local label="$1"
  local path="$2"

  if [[ -e "$path" ]]; then
    printf '%-28s OK %s\n' "$label:" "$path"
  else
    printf '%-28s MISSING %s\n' "$label:" "$path"
    status=1
  fi
}

printf '1C agent runtime doctor\n'
printf '=======================\n'
check_path "project mount" "$project_root"
check_path "agent registry" "$registry_path"
check_path "skills root" "/opt/onec-skills"
check_path "1C current symlink" "/opt/1cv8/current"

printf '%-28s ' "python3:"
if command -v python3 >/dev/null 2>&1; then
  python3 --version
else
  printf 'MISSING\n'
  status=1
fi

printf '%-28s ' "oscript:"
if command -v oscript >/dev/null 2>&1; then
  oscript --version
else
  printf 'MISSING\n'
  status=1
fi

printf '%-28s ' "vrunner:"
if command -v vrunner >/dev/null 2>&1; then
  vrunner version 2>/dev/null || vrunner help >/dev/null && printf 'OK\n'
else
  printf 'MISSING\n'
  status=1
fi

printf '%-28s ' "bsl-language-server:"
if command -v bsl-language-server >/dev/null 2>&1; then
  bsl-language-server --version
else
  printf 'MISSING\n'
  status=1
fi

printf '%-28s ' "onec-context:"
if command -v onec-context >/dev/null 2>&1; then
  onec-context --help | head -n 1
else
  printf 'MISSING\n'
  status=1
fi

printf '%-28s ' "onec-context-mcp:"
if command -v onec-context-mcp >/dev/null 2>&1; then
  onec-context-mcp --help | head -n 1
else
  printf 'MISSING\n'
  status=1
fi

printf '%-28s ' "onec-agent-context-mcp:"
if command -v onec-agent-context-mcp >/dev/null 2>&1; then
  onec-agent-context-mcp --help | head -n 1
else
  printf 'MISSING\n'
  status=1
fi

printf '%-28s ' "oacs:"
if command -v acs >/dev/null 2>&1; then
  acs --help >/dev/null && printf 'OK\n'
else
  printf 'disabled (optional)\n'
fi

if [[ -f "$registry_path" ]]; then
  context_manifest="$(jq -r '.tools["onec-context"].manifest // empty' "$registry_path")"
  context_platform_pack="$(jq -r '.packs.platform // empty' "$registry_path")"
  context_standards_pack="$(jq -r '.packs.standards // empty' "$registry_path")"
  context_standards_manifest="$(jq -r '.manifests.standards // empty' "$registry_path")"

  printf '\ncontext packs\n'
  if [[ -n "$context_manifest" ]]; then
    check_path "context manifest" "$context_manifest"
  else
    printf '%-28s MISSING registry tools.onec-context.manifest\n' "context manifest:"
    status=1
  fi

  if [[ -n "$context_platform_pack" ]]; then
    check_path "platform pack" "$context_platform_pack"
  else
    printf '%-28s MISSING registry packs.platform\n' "platform pack:"
    status=1
  fi

  if [[ -n "$context_standards_pack" ]]; then
    check_path "standards pack" "$context_standards_pack"
  else
    printf '%-28s MISSING registry packs.standards\n' "standards pack:"
    status=1
  fi

  if [[ -n "$context_standards_manifest" ]]; then
    check_path "standards manifest" "$context_standards_manifest"
  else
    printf '%-28s MISSING registry manifests.standards\n' "standards manifest:"
    status=1
  fi

  printf '\nskills\n'
  while IFS= read -r line; do
    entrypoint="${line#*: }"
    if [[ -f "$entrypoint" ]]; then
      printf '  OK      %s\n' "$line"
    else
      printf '  MISSING %s\n' "$line"
      status=1
    fi
  done < <(jq -r '.skills | to_entries[] | "\(.key): \(.value.entrypoint)"' "$registry_path")
fi

exit "$status"
