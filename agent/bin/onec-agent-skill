#!/usr/bin/env bash
set -euo pipefail

name="${1:-}"
registry_path="${ONEC_AGENT_REGISTRY:-/opt/onec-agent/registry.json}"

case "$name" in
  list)
    jq -r '.skills | keys[]' "$registry_path"
    exit 0
    ;;
  context)
    key="onec-context-toolkit"
    ;;
  testing|vanessa)
    key="onec-vanessa-skill"
    ;;
memory|agent-context|oacs)
    key="oacs-memory"
    ;;
  ""|-h|--help)
    printf 'Usage: onec-agent-skill <list|context|testing|memory>\n'
    exit 0
    ;;
  *)
    printf 'Unknown skill name: %s\n' "$name" >&2
    exit 2
    ;;
esac

entrypoint="$(jq -r --arg key "$key" '.skills[$key].entrypoint // empty' "$registry_path")"
if [[ -z "$entrypoint" || ! -f "$entrypoint" ]]; then
  printf 'Skill entrypoint is missing for %s: %s\n' "$key" "${entrypoint:-<empty>}" >&2
  exit 1
fi

cat "$entrypoint"
