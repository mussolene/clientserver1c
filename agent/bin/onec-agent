#!/usr/bin/env bash
set -euo pipefail

project_root="${ONEC_PROJECT_ROOT:-/workspace/project}"

usage() {
  cat <<'EOF'
Usage:
  onec-agent doctor
  onec-agent registry
  onec-agent skills
  onec-agent skill <context|testing|memory>
  onec-agent bslls [src-dir]
  onec-agent bslls-format <src-dir>
  onec-agent context [--task text] [--query text] [--pack platform|standards] [--limit n]
  onec-agent context-mcp [--debug]
  onec-agent context-mcp-config
  onec-agent memory-query --query text
  onec-agent memory-capture --summary text [--type procedure] [--depth 2] [--evidence ev_...]
  onec-agent exec -- <command...>

Run inside the Portable Agent Infrastructure container with a project mounted at /workspace/project,
or set ONEC_PROJECT_ROOT to another mounted path.
EOF
}

die() {
  printf '%s\n' "$*" >&2
  exit 2
}

cd_project() {
  [[ -d "$project_root" ]] || die "Project mount is missing: $project_root"
  cd "$project_root"
}

mode="${1:-}"
if [[ -n "$mode" ]]; then
  shift
fi

case "$mode" in
  doctor)
    exec onec-agent-doctor "$@"
    ;;
  registry)
    exec cat "${ONEC_AGENT_REGISTRY:-/opt/onec-agent/registry.json}"
    ;;
  skills)
    exec onec-agent-skill list
    ;;
  skill)
    [[ "$#" -ge 1 ]] || die "Usage: onec-agent skill <context|testing|memory>"
    exec onec-agent-skill "$@"
    ;;
  bslls)
    exec onec-agent-bslls "$@"
    ;;
  bslls-format)
    [[ "$#" -ge 1 ]] || die "Usage: onec-agent bslls-format <src-dir>"
    BSLLS_MODE=format exec onec-agent-bslls "$@"
    ;;
  context)
    exec onec-agent-context build "$@"
    ;;
  context-mcp)
    exec onec-agent-context-mcp "$@"
    ;;
  context-mcp-config)
    exec onec-agent-context mcp-config "$@"
    ;;
  memory-query)
    exec onec-agent-context query "$@"
    ;;
  memory-capture)
    exec onec-agent-context capture "$@"
    ;;
  exec)
    cd_project
    if [[ "${1:-}" == "--" ]]; then
      shift
    fi
    if [[ "$#" -eq 0 ]]; then
      exec bash
    fi
    exec "$@"
    ;;
  ""|-h|--help)
    usage
    ;;
  *)
    die "Unknown onec-agent command: $mode"
    ;;
esac
