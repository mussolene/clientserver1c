# Minimal local settings.
PLATFORM_VERSION=8.5.1.1302
PLATFORM_ARCH=amd64
ONEC_PROJECT_PATH=

# Docker image namespace. Default points at the published GHCR images.
# Set to mussolene to use Docker Hub, or to your own private registry namespace.
IMAGE_NAMESPACE=ghcr.io/mussolene

# Leave ITS_LOGIN / ITS_PASSWORD empty for local interactive make targets:
# they will prompt once and save values into .env.
ITS_LOGIN=
ITS_PASSWORD=

# PostgreSQL 1C is only needed for optional server/client-server mode.
POSTGRES_PASSWORD=change-me-local-only
PG_MAJOR=17
PG_1C_VERSION=17.7-1.1C
PG_REPO_DIST=bookworm

# Optional runtime overrides.
# DOCKER_DEFAULT_PLATFORM=linux/amd64
# ONEC_PLATFORM_OVERRIDE=native-arm
# ONEC_RUNTIME_MODE=license-ui
# ONEC_FILE_DB_PATH=/mnt/data/testdb

# Advanced pinned build inputs. Keep these unchanged for repeatable builds.
VANESSA_ADD_VERSION=6.9.5
VANESSA_RUNNER_VERSION=2.6.0
VANESSA_AUTOMATION_VERSION=1.2.043.1
BSLLS_VERSION=0.25.0
OACS_VERSION=0.3.1a2

ONEC_VANESSA_SKILL_REF=58b8e8b4831f4f1457707b037c8a050f5cd32e86
ONEC_CONTEXT_TOOLKIT_REF=6a1df34b06a7a71c65876298070cb13525896ee3
