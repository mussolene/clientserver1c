# POSTGRES_PASSWORD is only needed when you start the optional PostgreSQL 1C service.
POSTGRES_PASSWORD=change-me-local-only
PG_MAJOR=17
PG_1C_VERSION=17.7-1.1C
PG_REPO_DIST=bookworm
PLATFORM_VERSION=8.5.1.1302
PLATFORM_ARCH=amd64

# OPM tool versions baked into the developer image.
VANESSA_ADD_VERSION=6.9.5
VANESSA_RUNNER_VERSION=2.6.0
VANESSA_AUTOMATION_VERSION=1.2.043.1
BSLLS_VERSION=0.25.0

# Agent-ready skills layer refs. Pinned to commits for repeatable image builds.
ONEC_VANESSA_SKILL_REF=58b8e8b4831f4f1457707b037c8a050f5cd32e86
ONEC_CONTEXT_TOOLKIT_REF=b3ac817fa76d4979ae10bf5806e9d7bbab66e1e0
ONEC_WORKFLOW_PROOF_REF=29664a56b6eba063982cacc3e200285e09799933

# Host project repository to mount into 1c-dev at /workspace/project for IDE-agent workflows.
ONEC_PROJECT_PATH=
# DOCKER_DEFAULT_PLATFORM=linux/amd64
# ONEC_PLATFORM_OVERRIDE=native-arm
# ONEC_RUNTIME_MODE=license-ui
# ONEC_FILE_DB_PATH=/mnt/data/testdb
# Host-side platform staging happens before: make prepare-platform, make build,
# make up, make up-file-db, make up-server, and make build-server-stack.
# Leave ITS_LOGIN / ITS_PASSWORD empty for local interactive make targets:
# they will prompt once and save values into .env.
ITS_LOGIN=
ITS_PASSWORD=
