POSTGRES_PASSWORD=change-me-local-only
PG_MAJOR=17
PG_1C_VERSION=17.7-1.1C
PG_REPO_DIST=bookworm
PLATFORM_VERSION=8.3.22.1851
PLATFORM_ARCH=amd64
# DOCKER_DEFAULT_PLATFORM=linux/amd64
# Primary build flow uses docker compose build-time downloads from ITS.
# Leave ITS_LOGIN / ITS_PASSWORD empty for local interactive make targets:
# they will prompt once and save values into .env.
COMMON_BASE_IMAGE=mussolene/linux-common-base
COMMON_BASE_TAG=bookworm
COMMON_BASE_DIST=bookworm
DESKTOP_BASE_IMAGE=mussolene/linux-desktop-base
DESKTOP_BASE_TAG=bookworm
ONESCRIPT_BASE_IMAGE=mussolene/linux-onescript
ONESCRIPT_BASE_TAG=2.0.0
ONESCRIPT_BUILD_IMAGE=mussolene/linux-onescript-builder
ONESCRIPT_BUILD_TAG=2.0.0
ONESCRIPT_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:8.0
ONESCRIPT_VERSION=2.0.0
VANESSA_ADD_VERSION=6.9.5
VANESSA_RUNNER_VERSION=2.6.0
ITS_LOGIN=
ITS_PASSWORD=
